# --- Model provider -------------------------------------------------------
# Copy to `.env.local` and add your API key for a live copilot demo.
# Tests and evals force AI_PROVIDER=mock — no keys required for CI.
#
# Quick start (Anthropic):
#   cp .env.example .env.local
#   # set ANTHROPIC_API_KEY=sk-ant-...
#   pnpm db:seed && pnpm dev
AI_PROVIDER=anthropic         # anthropic | openai | bedrock | mock

# anthropic  (AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# openai     (AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# bedrock    (AI_PROVIDER=bedrock)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...        # if using temporary credentials
# BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20240620-v1:0

# --- Gateway (optional) ---------------------------------------------------
# Option A: set AI_GATEWAY_BASE_URL — routes anthropic/openai through your gateway.
# Option B: set AI_GATEWAY_API_KEY — uses the Vercel AI Gateway SDK (see provider.ts).
# AI_GATEWAY_BASE_URL=https://gateway.ai.cloudflare.com/v1/<account_id>/<gateway>/openai
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
# AI_GATEWAY_API_KEY=...

# --- Database -------------------------------------------------------------
# Directory for the file-backed PGlite database. The db:seed process and the
# `next dev` process share this directory so seeded data is visible in the app.
PGLITE_DIR=./.pglite
